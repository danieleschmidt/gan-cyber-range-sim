# GAN Cyber Range Simulator - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# AI/ML CONFIGURATION
# =============================================================================
# OpenAI Configuration (required for GPT-4 based agents)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Anthropic Configuration (required for Claude based agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# LangChain Configuration (optional but recommended for debugging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=gan-cyber-range

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database (primary data store)
DATABASE_URL=postgresql://cyber_range:secure_password@localhost:5432/cyber_range
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (caching and session storage)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# =============================================================================
# KUBERNETES CONFIGURATION
# =============================================================================
# Kubernetes cluster settings
KUBERNETES_NAMESPACE=cyber-range
KUBECONFIG=/path/to/your/kubeconfig
KUBERNETES_CONTEXT=your-cluster-context

# Service account and RBAC
KUBERNETES_SERVICE_ACCOUNT=cyber-range-sa
KUBERNETES_CLUSTER_ROLE=cyber-range-admin

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Application secrets (generate secure random values)
SECRET_KEY=your-secret-key-min-32-characters-long
ENCRYPTION_KEY=your-32-character-encryption-key!!
JWT_SECRET=your-jwt-secret-for-token-signing
JWT_EXPIRATION_HOURS=24

# API Security
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=3600
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# CYBER RANGE CONFIGURATION
# =============================================================================
# Range deployment settings
RANGE_ISOLATION_ENABLED=true
RANGE_RESOURCE_LIMITS_ENABLED=true
RANGE_NETWORK_POLICIES_ENABLED=true

# Agent configuration
RED_TEAM_AGENT_MODEL=gpt-4
BLUE_TEAM_AGENT_MODEL=claude-3-sonnet-20240229
AGENT_EXECUTION_TIMEOUT=300
AGENT_MAX_ACTIONS_PER_TURN=10

# Simulation settings
SIMULATION_SPEED_MULTIPLIER=60
SIMULATION_MAX_DURATION_HOURS=24
SIMULATION_AUTO_PAUSE_ON_ERROR=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Grafana dashboard
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin_password

# Jaeger tracing
JAEGER_ENABLED=true
JAEGER_COLLECTOR_ENDPOINT=http://localhost:14268/api/traces
JAEGER_SAMPLE_RATE=0.1

# Logging configuration
LOG_FORMAT=json
LOG_FILE=/var/log/cyber-range/app.log
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_DAYS=30

# =============================================================================
# EXTERNAL TOOL INTEGRATION
# =============================================================================
# Metasploit Framework
METASPLOIT_RPC_HOST=localhost
METASPLOIT_RPC_PORT=55553
METASPLOIT_RPC_USER=msfrpc
METASPLOIT_RPC_PASS=your_msf_password

# Nmap configuration
NMAP_SCAN_RATE=1000
NMAP_MAX_PARALLEL_SCANS=10
NMAP_TIMEOUT=300

# Nikto web scanner
NIKTO_MAX_SCAN_TIME=600
NIKTO_PLUGINS=@@ALL

# Custom tool configurations
CUSTOM_TOOLS_PATH=/opt/cyber-range/tools
TOOLS_CONFIG_PATH=/etc/cyber-range/tools

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Development mode flags
MOCK_SECURITY_TOOLS=false
FAST_MODE=false
SKIP_AUTHENTICATION=false
AUTO_RELOAD=true

# Testing configuration
PYTEST_MARKERS=unit,integration,security
TEST_DATABASE_URL=postgresql://cyber_range_test:password@localhost:5432/cyber_range_test
TEST_REDIS_URL=redis://localhost:6379/1

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Worker configuration
WORKER_PROCESSES=4
WORKER_THREADS=2
WORKER_TIMEOUT=30

# Cache settings
CACHE_TYPE=redis
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Request limits
MAX_REQUEST_SIZE=10MB
MAX_UPLOAD_SIZE=100MB
REQUEST_TIMEOUT=30

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
# Backup configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/var/backups/cyber-range

# S3 backup (optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-west-2
S3_BACKUP_BUCKET=cyber-range-backups

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================
# Email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#cyber-range-alerts

# Discord notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# =============================================================================
# COMPLIANCE & AUDITING
# =============================================================================
# Audit logging
AUDIT_ENABLED=true
AUDIT_LOG_PATH=/var/log/cyber-range/audit.log
AUDIT_RETENTION_DAYS=365

# Compliance settings
COMPLIANCE_MODE=SOC2
PCI_DSS_ENABLED=false
GDPR_ENABLED=true
HIPAA_ENABLED=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Experimental features
FEATURE_ADVANCED_AI=true
FEATURE_ZERO_DAY_SIMULATION=false
FEATURE_PHYSICAL_SECURITY=false
FEATURE_SOCIAL_ENGINEERING=true
FEATURE_IOT_SCENARIOS=false

# UI features
FEATURE_DARK_MODE=true
FEATURE_REAL_TIME_CHAT=true
FEATURE_COLLABORATIVE_MODE=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# MITRE ATT&CK
MITRE_ATTACK_API_ENABLED=true
MITRE_ATTACK_UPDATE_INTERVAL=24

# CVE database
CVE_DATABASE_ENABLED=true
CVE_UPDATE_SCHEDULE=0 4 * * *

# Threat intelligence feeds
THREAT_INTEL_ENABLED=false
THREAT_INTEL_API_KEY=your_threat_intel_api_key

# =============================================================================
# CUSTOM EXTENSIONS
# =============================================================================
# Plugin configuration
PLUGINS_ENABLED=true
PLUGINS_PATH=/opt/cyber-range/plugins
PLUGIN_AUTO_LOAD=true

# Custom scenarios
CUSTOM_SCENARIOS_PATH=/var/lib/cyber-range/scenarios
SCENARIO_VALIDATION_ENABLED=true

# =============================================================================
# NOTES
# =============================================================================
# 1. Replace all placeholder values with your actual configuration
# 2. Keep this file secure and never commit it to version control
# 3. Use environment-specific values for different deployments
# 4. Regularly rotate passwords and API keys
# 5. Validate configuration before deployment using: python -c "from gan_cyber_range.config import validate_config; validate_config()"